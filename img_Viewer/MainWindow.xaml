<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="img_Viewer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:model="using:img_Viewer.Models"
    xmlns:local="using:img_Viewer"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:media="using:Microsoft.UI.Xaml.Media"
    mc:Ignorable="d">

    <!-- 背景 -->
    <Window.SystemBackdrop>
        <media:MicaBackdrop />
    </Window.SystemBackdrop>

    <!--<Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>-->
    <!--<Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
            顶部栏 -->
    <Grid>
       
        <SplitView
        x:Name="MainSplitView"
        DisplayMode="CompactInline"
        IsPaneOpen="False"
        CompactPaneLength="51"
        OpenPaneLength="260">

            <SplitView.Pane>



                <StackPanel Spacing="8">
                    <Button Background="Transparent" BorderThickness="0" Padding="8" Click="OnPickFolderClicked">
                        <Grid ColumnSpacing="12">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <SymbolIcon Symbol="Folder"/>

                            <TextBlock
                            Grid.Column="1"
                            Text="选择文件夹"
                            VerticalAlignment="Center"/>

                        </Grid>
                    </Button>
                    <ListView
                        x:Name="FolderList"
                        Grid.Row="1"
                        Margin="16"
                        SelectionMode="Single"
                        SelectionChanged="FolderList_SelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">

                                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8B7;" VerticalAlignment="Center" />
                                    
                                    <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <Button Background="Transparent" BorderThickness="0" Padding="8" Click="OnDeleteFolderClicked">
                        <Grid ColumnSpacing="12">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <SymbolIcon Symbol="Delete"/>

                            <TextBlock
                            Grid.Column="1"
                            Text="删除路径"
                            VerticalAlignment="Center"/>

                        </Grid>
                    </Button>
                    <Button Background="Transparent" BorderThickness="0" Padding="8" x:Name="ImportButton" Click="ImportImages_Click">
                        <Grid ColumnSpacing="12">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <SymbolIcon Symbol="Pictures"/>

                            <TextBlock
                            Grid.Column="1"
                            Text="导入图片"
                            VerticalAlignment="Center"/>

                        </Grid>
                    </Button>
                    <Button Background="Transparent" BorderThickness="0" Padding="8" Click="StartAnalysis_Click">
                        <Grid ColumnSpacing="12">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <SymbolIcon Symbol="Play"/>

                            <TextBlock
                            Grid.Column="1"
                            Text="开始分析"
                            VerticalAlignment="Center"/>

                        </Grid>
                    </Button>
                    <Button Background="Transparent" BorderThickness="0" Padding="8" Click="ImportTagButton_Click">
                        <Grid ColumnSpacing="12">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <SymbolIcon Symbol="Play"/>

                            <TextBlock
                            Grid.Column="1"
                            Text="导入标签"
                            VerticalAlignment="Center"/>

                        </Grid>
                    </Button>
                    <Button
                        Content="☰"
                        Click="TogglePane_Click"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="10"/>
                </StackPanel>

            </SplitView.Pane>

            <SplitView.Content>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="600"/><!--缩略图 -->
                            <ColumnDefinition Width="*"/><!--大图并显示标签-->
                    </Grid.ColumnDefinitions>
                    <GridView
                    x:Name="ImageGrid"
                    Grid.Row="1"
                    Margin="16"
                    HorizontalAlignment="Right"
                    ItemsSource="{x:Bind ImagesToDisplay}"
                        
                        
                    Grid.Column="0"
                    SelectionMode="Single"    
                    IsItemClickEnabled="True"
                    ItemClick="ThumbnailGrid_ItemClick">
                        
                        <GridView.ItemTemplate>
                            <DataTemplate x:DataType="model:DisplayBigImage">
                                <Image Source="{x:Bind FilePath}" Width="200" Height="150" Stretch="Uniform"/>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                    <StackPanel Grid.Column="1" Margin="10">
                        <Image x:Name="LargeImage" Stretch="Uniform" Height="400"/>
                        <TextBlock x:Name="ImageTags" TextWrapping="Wrap" Margin="0,10,0,0"/>
                    </StackPanel>
                </Grid>
            </SplitView.Content>
        </SplitView>
        <!-- 主区域 -->
    </Grid>
</Window>
